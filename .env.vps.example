ADMIN_TOKEN=replace-with-long-random-token
AWG_INTERFACE=awg0
MOCK_AWG=false
AWG_BIN=awg
AWG_CONFIG_PATH=/etc/amnezia/amneziawg/awg0.conf
CLIENTS_DIR=/opt/awg-panel/data/clients
SERVER_ENDPOINT=YOUR_SERVER_IP:51820
CLIENT_DNS=1.1.1.1
CLIENT_ALLOWED_IPS=0.0.0.0/0, ::/0
CLIENT_PERSISTENT_KEEPALIVE=25
RELOAD_COMMAND=systemctl restart awg-quick@awg0.service
