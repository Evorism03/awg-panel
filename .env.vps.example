ADMIN_TOKEN=replace-with-long-random-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
AWG_INTERFACE=awg0
MOCK_AWG=false
AWG_BIN=awg
AWG_IMAGE=
AWG_CONTAINER_NAME=awg-panel-awg
AWG_HOST_CONFIG_DIR=/opt/amnezia/awg
AWG_DOCKER_CONTAINER=awg-panel-awg
AWG_CONFIG_PATH=/opt/awg-panel/data/awg0.conf
AWG_CONTAINER_CONFIG_PATH=/opt/amnezia/awg/awg0.conf
CLIENTS_DIR=/opt/awg-panel/data/clients
SERVER_ENDPOINT=YOUR_SERVER_IP:51820
CLIENT_DNS=1.1.1.1
CLIENT_ALLOWED_IPS=0.0.0.0/0, ::/0
CLIENT_PERSISTENT_KEEPALIVE=25
RELOAD_COMMAND=docker restart awg-panel-awg
QR_RENDERER_URL=http://qr-renderer:8091/render
PANEL_HTTP_BIND=0.0.0.0
PANEL_HTTP_PORT=8080
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8090
