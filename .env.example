ADMIN_TOKEN=change-me-long-random-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
INSTALL_MODE=panel
AWG_INTERFACE=awg0
MOCK_AWG=true
AWG_CONFIG_PATH=/data/awg0.conf
AWG_IMAGE=
AWG_CONTAINER_NAME=awg-panel-awg
AWG_HOST_CONFIG_DIR=./data/amneziawg
AWG_DOCKER_CONTAINER=
CLIENTS_DIR=/data/clients
SERVER_ENDPOINT=1.2.3.4:51820
CLIENT_DNS=1.1.1.1
CLIENT_ALLOWED_IPS=0.0.0.0/0, ::/0
CLIENT_PERSISTENT_KEEPALIVE=25
RELOAD_COMMAND=docker restart awg-panel-awg
